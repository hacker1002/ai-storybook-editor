# video-worker env — loaded via `node --env-file-if-exists=.env` (npm start).
# Native Node env-file: KEY=VALUE literal only, no ${} expansion, no shell.
# Copy to `.env` and fill in. Unset vars fall back to the defaults below.

# Express bind port. Server binds 127.0.0.1 (loopback) — expose via nginx reverse proxy.
PORT=4000

# Shared secret protecting POST /render*. Unset/empty → bypass (dev loopback).
# Production: REQUIRED. Generate: `openssl rand -hex 32`. Must match image-api video_worker_token.
VIDEO_WORKER_TOKEN=

# Public base URL of the worker (nginx server_name). Used to absolutize the
# relative /files/<book>.mp4 into the durable media_url. Must equal image-api
# video_worker_public_url. Example: https://video-worker.example.com
VIDEO_WORKER_PUBLIC_URL=

# Max bytes fetched for bgm.url (/render-book) — SSRF/OOM cap. Default 20MB.
BGM_MAX_BYTES=20971520
